    "question_text_vi": "Quy trình khai thác lỗ hổng bằng Exploit Code đúng thứ tự là gì?",
    "answers": [
      {
        "answer_text_en": "",
        "answer_text_vi": "Tìm kiếm lỗ hổng → Phát triển exploit → Triển khai tấn công → Duy trì truy cập → Xóa dấu vết",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Xóa dấu vết → Tìm kiếm → Triển khai → Phát triển → Duy trì",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Duy trì truy cập → Tìm kiếm → Phát triển → Xóa dấu vết → Triển khai",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Triển khai → Phát triển → Duy trì → Tìm kiếm → Xóa dấu vết",
        "is_correct": false
      }
    ]
