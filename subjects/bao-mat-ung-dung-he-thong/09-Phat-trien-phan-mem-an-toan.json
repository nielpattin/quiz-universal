    "question_id": "bm-m9-q1",
    "question_type": "single_answer_question",
    "question_text_en": "",
    "question_text_vi": "SSDLC (Secure Software Development Lifecycle) là gì?",
    "answers": [
      {
        "answer_text_en": "",
        "answer_text_vi": "Quy trình phát triển phần mềm tích hợp bảo mật trong từng giai đoạn vòng đời (yêu cầu → thiết kế → lập trình → kiểm thử → triển khai → bảo trì)",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Phần mềm diệt virus",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Chỉ kiểm thử bảo mật ở cuối vòng đời",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Giao thức mã hóa AES",
        "is_correct": false
      }
    ]
  },
  {
    "question_id": "bm-m9-q2",
    "question_type": "multiple_answer_question",
    "question_text_en": "",
    "question_text_vi": "Mục tiêu của SSDLC là gì?",
    "answers": [
      {
        "answer_text_en": "",
        "answer_text_vi": "Phát hiện và xử lý rủi ro sớm, giảm chi phí khắc phục",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Tích hợp bảo mật xuyên suốt vòng đời",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Tăng độ tin cậy, uy tín, tuân thủ chuẩn (ISO 27001, OWASP, GDPR)",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Xây dựng văn hóa bảo mật",
        "is_correct": true
      }
    ]
  },
  {
