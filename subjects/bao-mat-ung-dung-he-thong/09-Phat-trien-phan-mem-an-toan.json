    "question_text_en": "",
    "question_text_vi": "Quy trình Penetration Testing điển hình đúng thứ tự là gì?",
    "answers": [
      {
        "answer_text_en": "",
        "answer_text_vi": "Lập kế hoạch → Thu thập thông tin (recon) → Tấn công giả lập → Báo cáo lỗ hổng (PoC) → Vá lỗi → Retest",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Vá lỗi → Retest → Lập kế hoạch → Tấn công",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Tấn công → Lập kế hoạch → Recon → Báo cáo",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Recon → Vá lỗi → Tấn công → Báo cáo",
        "is_correct": false
      }
    ]
  },
