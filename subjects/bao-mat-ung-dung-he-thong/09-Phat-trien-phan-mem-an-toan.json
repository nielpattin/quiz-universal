      {
        "answer_text_en": "",
        "answer_text_vi": "Sửa sớm và muộn tốn như nhau",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Sửa muộn rẻ hơn",
        "is_correct": false
      }
