  {
    "question_id": "bm-m5-q51",
    "question_type": "single_answer_question",
    "question_text_en": "",
    "question_text_vi": "(PDF) So sánh Full Backup, Incremental Backup và Differential Backup — phát biểu nào đúng?",
    "answers": [
      {
        "answer_text_en": "",
        "answer_text_vi": "Full: sao lưu toàn bộ, dung lượng lớn, khôi phục nhanh; Incremental: chỉ lưu thay đổi từ lần gần nhất, nhỏ nhất, khôi phục lâu nhất; Differential: lưu thay đổi kể từ lần Full gần nhất, mức trung bình",
        "is_correct": true
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Full: nhỏ nhất, khôi phục chậm; Incremental: toàn bộ, nhanh nhất; Differential: không lưu thay đổi",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Cả ba loại đều sao lưu toàn bộ dữ liệu như nhau",
        "is_correct": false
      },
      {
        "answer_text_en": "",
        "answer_text_vi": "Differential luôn lớn hơn Full Backup",
        "is_correct": false
      }
    ]
